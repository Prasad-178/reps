# Required for any LLM-touching command (drill, profile --rebuild, jd parse, plan).
# Copy this file to .env (in the repo root or $REPS_HOME) and the `reps` binary
# auto-loads it. Real shell `export`s always win, so `.env` only fills gaps.
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides (also settable in ~/.reps/config.toml)
# REPS_HOME=~/.reps
# REPS_MODEL=google/gemini-2.0-flash-001
# REPS_EMBED_MODEL=openai/text-embedding-3-small
# REPS_JUDGE_MODEL=anthropic/claude-3.5-haiku

# OPTIONAL — frontend
# NEXT_PUBLIC_REPS_API=http://localhost:7777   # default; set only if backend runs elsewhere
# OPENAI_API_KEY=...                            # only if you set voice.tts_provider=openai
# ELEVENLABS_API_KEY=...                        # only if you set voice.tts_provider=elevenlabs
